# LastMile2Aurora — Environment Variables
# Copy this to .env and fill in your values

# AWS
AWS_REGION=us-east-1

# Aurora PostgreSQL (target)
PG_HOST=your-aurora-cluster.cluster-xxxxx.us-east-1.rds.amazonaws.com
PG_PORT=5432
PG_DATABASE=lastmile
PG_USER=your_pg_user
PG_PASSWORD=your_pg_password

# Oracle (source)
ORACLE_HOST=your-oracle-instance.xxxxx.us-east-1.rds.amazonaws.com
ORACLE_PORT=1521
ORACLE_SERVICE=YOUR_SERVICE_NAME
ORACLE_USER=your_oracle_user
ORACLE_PASSWORD=your_oracle_password

# Cognito
COGNITO_USER_POOL_ID=your-region_xxxxxxxxx
COGNITO_CLIENT_ID=your_client_id

# S3
S3_BUCKET=your-bucket-name

# Bedrock
BEDROCK_MODEL=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# Frontend (set during build)
VITE_COGNITO_USER_POOL_ID=your-region_xxxxxxxxx
VITE_COGNITO_CLIENT_ID=your_client_id
VITE_API_URL=https://your-cloudfront-domain.cloudfront.net
